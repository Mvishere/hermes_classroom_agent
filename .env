# Google OAuth client credentials file (from Google Cloud Console)
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# OAuth token cache
GOOGLE_TOKEN_PATH=token.json

# Polling interval in minutes
POLL_INTERVAL_MINUTES=5

# Local storage locations
DOWNLOAD_DIRECTORY=downloads
DATA_DIRECTORY=data
LOG_DIRECTORY=logs
STATE_PATH=data/state/processed.json
USER_STATUS_PATH=data/state/user_status.json
RAG_INDEX_PATH=data/rag/materials_index.json
RAG_SUMMARIES_PATH=data/rag/summaries.json

# Logging
LOG_LEVEL=INFO

# API retry tuning
API_MAX_RETRIES=5
API_BACKOFF_BASE_SECONDS=1.0
API_THROTTLE_SECONDS=0.2
FETCH_SUBMISSIONS=1

# OAuth local server port (0 = auto)
OAUTH_LOCAL_SERVER_PORT=0

# Allow Google to return a narrower scope set without failing OAuth
OAUTHLIB_RELAX_TOKEN_SCOPE=1

# RAG pipeline
RAG_ENABLED=1
EMBEDDING_MODEL_PATH=./models/minilm
LLM_BACKEND=ollama
LLM_MODEL_PATH=qwen2.5:7b
RAG_TOP_K=3
RAG_MAX_NEW_TOKENS=256
RAG_TEMPERATURE=0.2
RAG_DEVICE=cpu
PDF_EXTRACT_ENABLED=1
PDF_EXTRACT_MAX_CHARS=6000

# Force local-only model loading
TRANSFORMERS_OFFLINE=1

# RAG text chunking settings

RAG_CHUNK_SIZE_CHARS=2000
RAG_CHUNK_OVERLAP_CHARS=200
RAG_EXTRACT_MAX_CHARS=12000
RAG_CONTEXT_MAX_CHARS=4000
CHAT_MAX_HISTORY_TURNS=3
